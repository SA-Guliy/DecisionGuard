# Example only. Do not commit real secrets.
# Keep real passwords in local env or secret manager.

# Universal client DB settings (direct credentials mode)
CLIENT_DB_HOST=localhost
CLIENT_DB_PORT=5432
CLIENT_DB_NAME=client_db
CLIENT_DB_USER=
CLIENT_DB_PASS=
CLIENT_DB_LOADER_USER=
CLIENT_DB_LOADER_PASS=
CLIENT_DB_ADMIN_USER=
CLIENT_DB_ADMIN_PASS=

# Optional pg_service mode (if CLIENT_DB_HOST is empty)
CLIENT_DB_APP_SERVICE=client_app
CLIENT_DB_LOADER_SERVICE=client_loader
CLIENT_DB_ADMIN_SERVICE=client_admin
CLIENT_DB_APP_USER=client_app
CLIENT_DB_AGENT_RO_USER=client_agent_ro

# Backward-compatible aliases consumed by some scripts
PG_EXPECTED_DB=client_db
PG_DSN=
PG_DSN_LOADER=
PG_DSN_ADMIN=

# LLM settings
# GROQ_API_KEY must NOT be placed here — this file may be committed to git.
# Store the real key in ~/.groq_secrets (chmod 600) instead.
# The runtime loads it automatically from there on every run — no export needed.
#
# Setup (2 min, free):
#   1. Get key: console.groq.com → Sign Up → API Keys → Create
#   2. echo "GROQ_API_KEY=gsk_..." > ~/.groq_secrets
#   3. echo "LLM_ALLOW_REMOTE=1"  >> ~/.groq_secrets
#   4. chmod 600 ~/.groq_secrets
#   5. Verify: python3 scripts/debug_groq_api.py  (expect http_status=200)
#
# Without a key, agents run in deterministic fallback (no AI reasoning, semantic_score=0).
LLM_BACKEND=groq
GROQ_API_KEY=

# Sanitization envelope settings (DO NOT USE IN PRODUCTION).
# SANITIZATION_KMS_MASTER_KEY below is a local demo placeholder only.
SANITIZATION_KMS_MASTER_KEY=local_demo_key
SANITIZATION_READER_ROLE=runtime_orchestrator
