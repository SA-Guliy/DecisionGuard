# Example only. Do not commit real secrets.
# Keep real passwords in local env or secret manager.

# Universal client DB settings (direct credentials mode)
CLIENT_DB_HOST=localhost
CLIENT_DB_PORT=5432
CLIENT_DB_NAME=client_db
CLIENT_DB_USER=
CLIENT_DB_PASS=
CLIENT_DB_LOADER_USER=
CLIENT_DB_LOADER_PASS=
CLIENT_DB_ADMIN_USER=
CLIENT_DB_ADMIN_PASS=

# Optional pg_service mode (if CLIENT_DB_HOST is empty)
CLIENT_DB_APP_SERVICE=client_app
CLIENT_DB_LOADER_SERVICE=client_loader
CLIENT_DB_ADMIN_SERVICE=client_admin
CLIENT_DB_APP_USER=client_app
CLIENT_DB_AGENT_RO_USER=client_agent_ro

# Backward-compatible aliases consumed by some scripts
PG_EXPECTED_DB=client_db
PG_DSN=
PG_DSN_LOADER=
PG_DSN_ADMIN=

# LLM settings (secrets must stay local; never commit real keys)
LLM_BACKEND=groq
GROQ_API_KEY=

# Sanitization envelope settings (local demo is supported with any non-empty string)
SANITIZATION_KMS_MASTER_KEY=local_demo_key
SANITIZATION_READER_ROLE=runtime_orchestrator
