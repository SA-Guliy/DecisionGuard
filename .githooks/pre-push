#!/usr/bin/env bash
# pre-push hook: blocks pushes when changed files match deny patterns for public repo policy.
# Install: git config core.hooksPath .githooks

set -euo pipefail

DENYLIST_FILE="PUBLISH_DENYLIST.txt"
STATIC_SENSITIVE_PATTERNS=(
  ".env"
  ".env.local"
  ".env.development"
  ".env.test"
  ".env.production"
  "**/.env"
  "**/.env.local"
  "**/.env.development"
  "**/.env.test"
  "**/.env.production"
  ".groq_secrets"
  "**/.groq_secrets"
)
ALLOW_EXACT_FILES=(
  ".env.example"
)

trim_line() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

load_deny_patterns() {
  local patterns=()
  if [[ ! -f "$DENYLIST_FILE" ]]; then
    echo "⛔ PRE-PUSH BLOCK: missing deny policy file: $DENYLIST_FILE"
    echo "Push aborted."
    exit 1
  fi
  while IFS= read -r raw; do
    local line
    line="$(trim_line "$raw")"
    [[ -z "$line" || "$line" == \#* ]] && continue
    patterns+=("$line")
  done < "$DENYLIST_FILE"
  patterns+=("${STATIC_SENSITIVE_PATTERNS[@]}")
  printf '%s\n' "${patterns[@]}"
}

pattern_matches_file() {
  local file="$1"
  local pattern="$2"
  if [[ "$pattern" == *"*"* || "$pattern" == *"?"* || "$pattern" == *"["* ]]; then
    [[ "$file" == $pattern ]]
    return $?
  fi
  [[ "$file" == "$pattern" ]]
  return $?
}

is_explicitly_allowed() {
  local file="$1"
  for allowed in "${ALLOW_EXACT_FILES[@]}"; do
    if [[ "$file" == "$allowed" ]]; then
      return 0
    fi
  done
  return 1
}

REMOTE="$1"
URL="$2"
DENY_PATTERNS=()
while IFS= read -r pattern; do
  [[ -z "$pattern" ]] && continue
  DENY_PATTERNS+=("$pattern")
done < <(load_deny_patterns)

# Collect all files that would be pushed (new commits vs remote)
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue  # deleting branch, skip
  fi

  # Only check files being ADDED or MODIFIED — not deleted (D status).
  # Deletions are safe and should not be blocked.
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    files=$(git diff-tree --no-commit-id -r --diff-filter=AM --name-only "$local_sha" 2>/dev/null || true)
  else
    range="$remote_sha..$local_sha"
    files=$(git diff --diff-filter=AM --name-only "$range" 2>/dev/null || true)
  fi

  BLOCKED=()
  for file in $files; do
    if is_explicitly_allowed "$file"; then
      continue
    fi
    for pattern in "${DENY_PATTERNS[@]}"; do
      if pattern_matches_file "$file" "$pattern"; then
        BLOCKED+=("  BLOCKED: $file  (matches pattern: $pattern)")
        break
      fi
    done
  done

  if [ ${#BLOCKED[@]} -gt 0 ]; then
    echo ""
    echo "⛔ PRE-PUSH BLOCK: The following files should NOT be pushed to a public repo:"
    for msg in "${BLOCKED[@]}"; do
      echo "$msg"
    done
    echo ""
    echo "Run: git rm --cached <file>  to untrack, then update .gitignore"
    echo "Push aborted."
    exit 1
  fi

done

exit 0
