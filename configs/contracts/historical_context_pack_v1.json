{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "historical_context_pack_v1.json",
  "title": "Historical Context Pack v1",
  "type": "object",
  "required": [
    "version",
    "run_id",
    "generated_at",
    "status",
    "retrieval_mode",
    "query_ref",
    "embedding_model",
    "top_k",
    "fact_refs",
    "evidence_hashes",
    "retrieval_policy",
    "rows"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {"const": "historical_context_pack_v1"},
    "run_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "status": {"type": "string", "enum": ["PASS", "FAIL"]},
    "retrieval_mode": {"type": "string", "const": "semantic_hybrid_mvp"},
    "query_ref": {"type": "string", "minLength": 1},
    "embedding_model": {"type": "string", "minLength": 1},
    "top_k": {"type": "integer", "minimum": 1, "maximum": 20},
    "fact_refs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {"type": "string", "minLength": 1}
    },
    "evidence_hashes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["artifact_ref", "sha256"],
        "additionalProperties": false,
        "properties": {
          "artifact_ref": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "retrieval_policy": {
      "type": "object",
      "required": ["top_k", "min_overlap_metrics", "source"],
      "additionalProperties": false,
      "properties": {
        "top_k": {"type": "integer", "minimum": 1},
        "min_overlap_metrics": {"type": "integer", "minimum": 1},
        "source": {"type": "string", "minLength": 1}
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": [
          "source_run_id",
          "similarity_score",
          "overlap_metric_count",
          "evidence_refs"
        ],
        "additionalProperties": false,
        "properties": {
          "source_run_id": {"type": "string", "minLength": 1},
          "similarity_score": {"type": "number", "minimum": 0, "maximum": 1},
          "overlap_metric_count": {"type": "integer", "minimum": 0},
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "items": {"type": "string", "minLength": 1}
          },
          "summary": {"type": "string", "maxLength": 500}
        }
      }
    },
    "error_code": {"type": "string"},
    "blocked_by": {"type": "array", "items": {"type": "string"}},
    "required_actions": {"type": "array", "items": {"type": "string"}}
  }
}
