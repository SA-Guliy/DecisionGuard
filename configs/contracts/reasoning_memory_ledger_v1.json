{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "reasoning_memory_ledger_v1.json",
  "title": "Reasoning Memory Ledger v1",
  "type": "object",
  "required": [
    "version",
    "run_id",
    "generated_at",
    "entries"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {"const": "reasoning_memory_ledger_v1"},
    "run_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date-time"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": [
          "stage",
          "artifact_ref",
          "used",
          "recorded_at"
        ],
        "additionalProperties": false,
        "properties": {
          "stage": {"type": "string", "minLength": 1},
          "artifact_ref": {"type": "string", "minLength": 1},
          "used": {"type": "boolean"},
          "usage_note": {"type": "string", "maxLength": 300},
          "recorded_at": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}
