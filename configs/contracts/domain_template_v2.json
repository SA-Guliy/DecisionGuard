{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Template Contract v2",
  "type": "object",
  "required": [
    "contract_version",
    "template_id",
    "template_metadata",
    "metrics_dictionary",
    "goals_taxonomy",
    "evaluation_rules",
    "data_mapping_rules",
    "runtime_bindings"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "domain_template.v2"
    },
    "template_id": {
      "type": "string",
      "minLength": 1
    },
    "template_metadata": {
      "type": "object",
      "required": [
        "domain_name",
        "description",
        "version"
      ],
      "properties": {
        "domain_name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "metrics_dictionary": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/metric_definition"
      }
    },
    "goals_taxonomy": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evaluation_rules": {
      "type": "object",
      "required": [
        "require_canonical_denominator",
        "fallback_status_on_api_failure"
      ],
      "properties": {
        "require_canonical_denominator": {
          "type": "boolean"
        },
        "fallback_status_on_api_failure": {
          "type": "string",
          "enum": [
            "STOP",
            "HOLD_NEED_DATA",
            "PASS"
          ]
        }
      },
      "additionalProperties": false
    },
    "data_mapping_rules": {
      "type": "object",
      "required": [
        "forbid_implicit_fallback",
        "on_mismatch_action",
        "writeoff_reason_column",
        "required_sources"
      ],
      "properties": {
        "forbid_implicit_fallback": {
          "type": "boolean",
          "const": true
        },
        "on_mismatch_action": {
          "type": "string",
          "enum": [
            "HOLD_NEED_DATA"
          ]
        },
        "writeoff_reason_column": {
          "type": "string",
          "pattern": "^[a-z_][a-z0-9_]*$"
        },
        "required_sources": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/source_mapping"
          }
        }
      },
      "additionalProperties": false
    },
    "runtime_bindings": {
      "type": "object",
      "required": [
        "metrics",
        "goals",
        "target_metric_to_primary_metric",
        "metric_to_goal",
        "guardrails_by_component",
        "doctor",
        "captain"
      ],
      "properties": {
        "metrics": {
          "$ref": "#/$defs/runtime_metrics"
        },
        "goals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/goal_row"
          }
        },
        "target_metric_to_primary_metric": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "metric_to_goal": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "guardrails_by_component": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/guardrail_row"
            }
          }
        },
        "doctor": {
          "$ref": "#/$defs/doctor"
        },
        "captain": {
          "$ref": "#/$defs/captain"
        }
      },
      "additionalProperties": false
    },
    "experiment_variants": {
      "type": "object",
      "required": [
        "ctrl",
        "treatment"
      ],
      "properties": {
        "ctrl": {
          "$ref": "#/$defs/experiment_variant"
        },
        "treatment": {
          "$ref": "#/$defs/experiment_variant"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "metric_definition": {
      "type": "object",
      "required": [
        "role",
        "direction_is_good",
        "scale",
        "unit",
        "business_meaning"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "primary_target",
            "secondary_target",
            "guardrail",
            "supporting"
          ]
        },
        "direction_is_good": {
          "type": "string",
          "enum": [
            "increase",
            "decrease",
            "neutral"
          ]
        },
        "scale": {
          "type": "string",
          "enum": [
            "percentage",
            "absolute"
          ]
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "business_meaning": {
          "type": "string",
          "minLength": 1
        },
        "canonical_denominator": {
          "type": "string",
          "minLength": 1
        },
        "hard_threshold_min": {
          "type": "number"
        },
        "hard_threshold_max": {
          "type": "number"
        },
        "breach_action": {
          "type": "string",
          "enum": [
            "STOP",
            "HOLD_NEED_DATA",
            "PASS"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "const": "guardrail"
              }
            }
          },
          "then": {
            "required": [
              "breach_action"
            ],
            "anyOf": [
              {
                "required": [
                  "hard_threshold_min"
                ]
              },
              {
                "required": [
                  "hard_threshold_max"
                ]
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "scale": {
                "const": "percentage"
              }
            }
          },
          "then": {
            "properties": {
              "hard_threshold_min": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "hard_threshold_max": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "source_mapping": {
      "type": "object",
      "required": [
        "required_columns"
      ],
      "properties": {
        "required_columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "allowed_columns": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z_][a-z0-9_]*$"
          },
          "uniqueItems": true
        },
        "enforce_allowed_columns": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "experiment_variant": {
      "type": "object",
      "required": [
        "mode_tag",
        "horizon_days",
        "seed"
      ],
      "properties": {
        "mode_tag": {
          "type": "string",
          "minLength": 1
        },
        "horizon_days": {
          "type": "integer",
          "minimum": 1
        },
        "seed": {
          "type": "integer"
        },
        "overrides": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "runtime_metrics": {
      "type": "object",
      "required": [
        "primary",
        "secondary",
        "required_denominators",
        "goal_metric_groups"
      ],
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_denominators": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "goal_metric_groups": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "additionalProperties": false
    },
    "goal_row": {
      "type": "object",
      "required": [
        "goal_id",
        "target_metric",
        "default_primary_metric",
        "commander_default_metric",
        "expected_direction",
        "risk_note"
      ],
      "properties": {
        "goal_id": {
          "type": "string",
          "minLength": 1
        },
        "target_metric": {
          "type": "string",
          "minLength": 1
        },
        "default_primary_metric": {
          "type": "string",
          "minLength": 1
        },
        "commander_default_metric": {
          "type": "string",
          "minLength": 1
        },
        "expected_direction": {
          "type": "string",
          "enum": [
            "increase",
            "decrease",
            ""
          ]
        },
        "risk_note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "guardrail_row": {
      "type": "object",
      "required": [
        "metric",
        "op",
        "threshold"
      ],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "enum": [
            ">=",
            "<=",
            ">",
            "<"
          ]
        },
        "threshold": {
          "type": "number"
        },
        "dynamic_baseline_ratio": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "doctor": {
      "type": "object",
      "required": [
        "thresholds",
        "required_ready_now",
        "blocked_phase2_metrics",
        "captain_issue_policies",
        "run_config_rules"
      ],
      "properties": {
        "thresholds": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "number",
              "integer",
              "string",
              "boolean"
            ]
          }
        },
        "required_ready_now": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blocked_phase2_metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "captain_issue_policies": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "run_config_rules": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "captain": {
      "type": "object",
      "required": [
        "allowed_sql_tables",
        "sql_step_templates"
      ],
      "properties": {
        "allowed_sql_tables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "sql_step_templates": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    }
  }
}
