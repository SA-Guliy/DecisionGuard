{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReconciliationResultV1",
  "type": "object",
  "required": [
    "event_id",
    "run_id",
    "experiment_id",
    "reconciliation_id",
    "source_event_id",
    "reconciliation_status",
    "attempt_no",
    "max_attempts",
    "auto_decision_change_applied",
    "completed_at",
    "loop_guard_key"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "experiment_id": { "type": "string", "minLength": 1 },
    "reconciliation_id": { "type": "string", "minLength": 1 },
    "source_event_id": { "type": "string", "minLength": 1 },
    "reconciliation_status": {
      "type": "string",
      "enum": ["COMPLETED", "EXPIRED", "FAILED"]
    },
    "attempt_no": { "type": "integer", "minimum": 1 },
    "max_attempts": { "type": "integer", "minimum": 1 },
    "auto_decision_change_applied": {
      "type": "boolean",
      "const": false
    },
    "completed_at": { "type": "string", "format": "date-time" },
    "loop_guard_key": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
