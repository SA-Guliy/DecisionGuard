{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CausalClaimsGroundedV2",
  "type": "object",
  "required": [
    "run_id",
    "experiment_id",
    "claims",
    "evidence_refs",
    "grounded_status",
    "issues"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "experiment_id": { "type": "string", "minLength": 1 },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "statement"],
        "properties": {
          "claim_id": { "type": "string" },
          "statement": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "grounded_status": { "type": "string", "enum": ["PASS", "WARN", "FAIL"] },
    "issues": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
