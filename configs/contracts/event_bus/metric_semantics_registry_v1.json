{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetricSemanticsRegistryV1",
  "type": "object",
  "required": [
    "metric_id",
    "metric_semantics_id",
    "formula",
    "numerator",
    "denominator",
    "grain",
    "window",
    "direction"
  ],
  "properties": {
    "metric_id": { "type": "string", "minLength": 1 },
    "metric_semantics_id": { "type": "string", "minLength": 1 },
    "formula": { "type": "string", "minLength": 1 },
    "numerator": { "type": ["string", "null"] },
    "denominator": { "type": ["string", "null"] },
    "grain": { "type": "string", "minLength": 1 },
    "window": { "type": "string", "minLength": 1 },
    "direction": { "type": "string", "enum": ["up", "down", "neutral", "depends"] }
  },
  "additionalProperties": true
}
