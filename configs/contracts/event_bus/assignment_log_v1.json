{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssignmentLogV1",
  "type": "object",
  "required": [
    "run_id",
    "experiment_id",
    "unit_id",
    "unit_type",
    "arm",
    "assignment_ts",
    "hash_salt_version"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "experiment_id": { "type": "string", "minLength": 1 },
    "unit_id": { "type": "string", "minLength": 1 },
    "unit_type": { "type": "string", "enum": ["customer", "store", "store_week"] },
    "arm": { "type": "string", "minLength": 1 },
    "assignment_ts": { "type": "string", "format": "date-time" },
    "hash_salt_version": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
